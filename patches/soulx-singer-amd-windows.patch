+def _session_keep_count() -> int:
+	raw_value = os.environ.get(SESSION_KEEP_ENV, str(SESSION_KEEP_DEFAULT))
+	try:
+		return max(1, int(raw_value))
+	except (TypeError, ValueError):
+		print(
