+		if path.resolve() not in ACTIVE_SESSIONS and _is_managed_session_dir(path)
+	}
+	keep_unprotected = max(0, _session_keep_count() - len(protected_completed))
+	candidates.sort(key=lambda item: item[0], reverse=True)
+	for _, old_session in candidates[keep_unprotected:]:
+		# Revalidate immediately before deletion to guard against path changes.
+		if old_session in ACTIVE_SESSIONS or not _is_managed_session_dir(old_session):
+			continue
+		try:
+			shutil.rmtree(old_session)
+			print(f"[session cleanup] removed {old_session.name}", flush=True)
+		except OSError as e:
+			print(f"[session cleanup] could not remove {old_session.name}: {e}", file=sys.stderr, flush=True)
+
+
+def _cleanup_session_dirs(protect: set[Path] | None = None) -> None:
+	with SESSION_LOCK:
