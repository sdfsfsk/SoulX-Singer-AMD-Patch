+
+def _is_managed_session_dir(path: Path) -> bool:
+	"""Only accept direct children that this module can identify as SVC sessions."""
+	try:
+		resolved = path.resolve()
+		if resolved.parent != SESSION_ROOT or not resolved.is_dir():
+			return False
+		if (resolved / SESSION_MARKER).is_file():
+			return True
+		# Sessions produced by older revisions did not have an ownership marker.
+		return bool(SESSION_NAME_RE.fullmatch(resolved.name)) and any(
+			(resolved / child).exists()
+			for child in ("audio", "transcriptions", "generated")
+		)
+	except OSError:
+		return False
+
+
+def _cleanup_session_dirs_locked(protect: set[Path] | None = None) -> None:
+	"""Keep the newest completed sessions without touching active/current work."""
+	SESSION_ROOT.mkdir(parents=True, exist_ok=True)
+	protected = {path.resolve() for path in (protect or set())}
+	protected.update(ACTIVE_SESSIONS)
+
+	candidates: list[tuple[float, Path]] = []
+	for child in SESSION_ROOT.iterdir():
+		if not _is_managed_session_dir(child):
+			continue
+		resolved = child.resolve()
+		if resolved in protected:
+			continue
+		try:
+			candidates.append((resolved.stat().st_mtime, resolved))
+		except OSError:
+			continue
+
+	# A protected completed/current session consumes one retention slot. Active
+	# sessions do not, because they are not completed yet.
+	protected_completed = {
